{
  "name": "nafaq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "electrobun dev",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run dev\"",
    "hmr": "vite --port 5173",
    "build": "vite build && electrobun build --env=canary",
    "build:sidecar": "cd sidecar && cargo build --release"
  },
  "dependencies": {
    "electrobun": "latest",
    "vue": "^3.5",
    "vue-router": "4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^5",
    "concurrently": "^9",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7",
    "vite": "^6"
  }
}
