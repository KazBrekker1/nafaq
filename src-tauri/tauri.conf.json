{
  "productName": "Nafaq",
  "version": "0.5.0",
  "identifier": "com.nafaq.app",
  "build": {
    "beforeBuildCommand": "bun generate",
    "frontendDist": "../.output/public",
    "beforeDevCommand": "PORT=3001 bun dev",
    "devUrl": "http://localhost:3001"
  },
  "app": {
    "windows": [
      {
        "title": "Nafaq",
        "width": 1100,
        "height": 750,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
